DATABASE_URL="postgresql://postgres:postgres@localhost:5432/crm_gym?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="1d"
PORT=4000
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"
NODE_ENV="development"

# Used only when creating the first admin with `npm run prisma:seed`.
# Existing admin passwords are never overwritten by seed.
ADMIN_LOGIN="admin"
ADMIN_PASSWORD="change-this-local-password"
