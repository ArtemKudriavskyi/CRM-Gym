generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionType {
  MONTH
  THREE_MONTHS
  STUDENT
}

model Admin {
  id           String @id @default(uuid()) @db.Uuid
  login        String @unique
  passwordHash String
}

model Client {
  id            String         @id @default(uuid()) @db.Uuid
  fullName      String
  phone         String         @unique
  birthDate     DateTime
  photoUrl      String?
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
  visits        Visit[]
  payments      Payment[]
}

model Subscription {
  id        String           @id @default(uuid()) @db.Uuid
  clientId  String           @db.Uuid
  type      SubscriptionType
  startDate DateTime
  endDate   DateTime
  price     Int
  isActive  Boolean          @default(true)
  client    Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  payments  Payment[]

  @@index([clientId])
  @@index([endDate])
}

model Visit {
  id             String   @id @default(uuid()) @db.Uuid
  clientId       String   @db.Uuid
  visitTimestamp DateTime @default(now())
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([visitTimestamp])
}

model Payment {
  id               String       @id @default(uuid()) @db.Uuid
  clientId         String       @db.Uuid
  subscriptionId   String       @db.Uuid
  amount           Int
  paymentTimestamp DateTime     @default(now())
  client           Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subscription     Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([subscriptionId])
  @@index([paymentTimestamp])
}
